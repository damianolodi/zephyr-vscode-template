{
    "env": {
        "myIncludePath": [
            "${workspaceFolder}/src"
        ],
        "myDefines": []
    },
    "configurations": [
        {
            "name": "Linux",
            "compilerPath": "/usr/local/lib/zephyr-sdk-0.16.3/arm-zephyr-eabi/bin/arm-zephyr-eabi-gcc",
            "intelliSenseMode": "linux-gcc-arm",
            "includePath": [
                "${myIncludePath}"
            ],
            "cStandard": "c11",
            "cppStandard": "c++20",
            "configurationProvider": "ms-vscode.cmake-tools",
            "mergeConfigurations": true
        }
    ],
    "version": 4,
    "enableConfigurationSquiggles": true
}